# ============================================================================
# PostgreSQL Configuration
# ============================================================================

# Credentials
POSTGRES_DB=mydb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Port
POSTGRES_PORT=5432

# ============================================================================
# Performance Tuning (adjust based on available RAM)
# ============================================================================

# For 8GB RAM machine: shared_buffers=2GB, effective_cache_size=6GB
# For 4GB RAM machine: shared_buffers=1GB, effective_cache_size=3GB
# For 16GB RAM machine: shared_buffers=4GB, effective_cache_size=12GB

POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=1GB
POSTGRES_EFFECTIVE_CACHE_SIZE=3GB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAINTENANCE_WORK_MEM=256MB

# Log queries slower than this (ms), 0 = log all, -1 = disable
POSTGRES_LOG_MIN_DURATION=1000

# Statement timeout (ms) - kill queries running longer than this
POSTGRES_STATEMENT_TIMEOUT=30000

# ============================================================================
# Docker Resource Limits
# ============================================================================

POSTGRES_MEMORY_LIMIT=6G
POSTGRES_MEMORY_RESERVATION=3G

# ============================================================================
# Connection URL for your app:
# postgresql://postgres:your_secure_password_here@<host>:5432/mydb
# ============================================================================
